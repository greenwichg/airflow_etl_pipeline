{
  "name": "retail-sales-cdc-europe",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "${POSTGRES_EUROPE_HOST}",
    "database.port": "5432",
    "database.user": "${POSTGRES_EUROPE_USER}",
    "database.password": "${POSTGRES_EUROPE_PASSWORD}",
    "database.dbname": "sales_europe",
    "database.server.name": "europe",
    "topic.prefix": "cdc.retail",
    "schema.include.list": "sales",
    "table.include.list": "sales.transactions",
    "plugin.name": "pgoutput",
    "slot.name": "debezium_europe",
    "publication.name": "dbz_publication_europe",
    "decimal.handling.mode": "double",
    "time.precision.mode": "connect",
    "tombstones.on.delete": "true",
    "column.include.list": "sales.transactions.sale_id,sales.transactions.customer_id,sales.transactions.product_id,sales.transactions.sale_date,sales.transactions.quantity,sales.transactions.unit_price,sales.transactions.total_amount,sales.transactions.store_id,sales.transactions.payment_method,sales.transactions.discount_amount,sales.transactions.tax_amount,sales.transactions.created_at,sales.transactions.updated_at,sales.transactions.is_deleted,sales.transactions.status",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "snapshot.mode": "initial",
    "heartbeat.interval.ms": "10000",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq.cdc.retail.europe",
    "errors.deadletterqueue.context.headers.enable": "true",
    "transforms": "route,addRegion",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "cdc\\.retail\\.sales\\.transactions",
    "transforms.route.replacement": "cdc.retail.sales.transactions",
    "transforms.addRegion.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.addRegion.static.field": "region",
    "transforms.addRegion.static.value": "europe"
  }
}
